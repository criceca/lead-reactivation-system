# ============ LLM Configuration ============
# IMPORTANTE: Solo activa UNO de los proveedores (el primero en True se usa)
# Orden de prioridad: OpenRouter > DeepSeek > OpenAI > Bedrock

# Opción 1: OpenAI (Recomendado para producción)
USE_OPENAI=False
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7

# Opción 2: OpenRouter (Modelos gratuitos y de pago)
USE_OPENROUTER=False
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct
# Modelos gratuitos populares:
# - qwen/qwen-2.5-72b-instruct (Gratis, muy bueno)
# - meta-llama/llama-3.1-8b-instruct:free (Gratis)
# - google/gemini-flash-1.5 (Gratis)
# Modelos de pago:
# - anthropic/claude-3.5-sonnet (Mejor calidad)
# - openai/gpt-4-turbo (Muy bueno)
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=Lead Reactivation System

# Opción 3: DeepSeek (Muy barato, buena calidad)
USE_DEEPSEEK=False
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat
# Modelos disponibles:
# - deepseek-chat (Conversación general, $0.14/1M tokens)
# - deepseek-coder (Código, $0.14/1M tokens)

# Opción 4: AWS Bedrock (Alternativa empresarial)
USE_BEDROCK=False
# Modelos recomendados:
# - anthropic.claude-3-5-sonnet-20240620-v1:0 (MEJOR - Más nuevo)
# - anthropic.claude-3-opus-20240229-v1:0 (Muy bueno)
# - anthropic.claude-3-sonnet-20240229-v1:0 (Bueno)
# - meta.llama2-70b-chat-v1 (Alternativa)
BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_REGION=us-east-1

# ============ AWS Credentials (Para Bedrock) ============
# Estas credenciales se usan TAMBIÉN para Bedrock
# Asegúrate de que tengan permisos para acceder a Bedrock
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SESSION_TOKEN=your-session-token-optional

# ============ Database Configuration ============
# SQLite (default - no server needed)
DATABASE_URL=sqlite:///./lead_reactivation.db
# Para MySQL, usa: mysql+pymysql://user:password@localhost:3306/lead_reactivation
DATABASE_ECHO=False

# ============ Telegram Configuration ============
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id

# ============ Email Configuration (Opcional ) ============
ENABLE_EMAIL_NOTIFICATIONS=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@leadreactivation.com
SALES_TEAM_EMAIL=sales@company.com

# ============ AWS S3 Configuration ============
# Usa las mismas credenciales de arriba (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# ============ API Configuration ============
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=True

# ============ Streamlit Configuration ============
STREAMLIT_PORT=8501

# ============ Agent Configuration ============
AGENT_TIMEOUT=300
MAX_CONVERSATION_TURNS=20
AGENT_DEBUG=False

# ============ Conversation Channel ============
CONVERSATION_CHANNEL=telegram

# ============ Environment ============
ENVIRONMENT=development
LOG_LEVEL=INFO
